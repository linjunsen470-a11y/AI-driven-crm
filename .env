# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Maoshan AI CRM
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/maoshan_ai_crm?schema=public"
# Optional: use a dedicated shadow database for migrations if needed
# SHADOW_DATABASE_URL="postgresql://username:password@localhost:5432/maoshan_ai_crm_shadow?schema=public"

# Auth
AUTH_SECRET=replace_with_a_long_random_secret_not_real

# Storage
STORAGE_DRIVER=minio
STORAGE_LOCAL_ROOT=./.data/storage
STORAGE_BUCKET=crm-files

# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=replace_with_minio_access_key
S3_SECRET_KEY=replace_with_minio_secret_key
S3_FORCE_PATH_STYLE=true

# n8n
N8N_ENABLED=true
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_PATH=/webhook/my-app
N8N_WEBHOOK_AUTH_ENABLED=true
N8N_WEBHOOK_AUTH_HEADER=X-Webhook-Token
N8N_WEBHOOK_SECRET=replace_with_random_secret_not_real

# AI providers
AI_ENABLED=true
OPENAI_API_KEY=
# Leave empty to use the default OpenAI API base URL
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4

# Speech / OCR defaults
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OCR_MODEL=gpt-5.4-mini

# Knowledge / RAG
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

# Upload / request limits
MAX_UPLOAD_SIZE_MB=25
WEBHOOK_REQUEST_TIMEOUT_MS=10000
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=2

# Logging
LOG_LEVEL=info
LOG_REDACT_SECRETS=true