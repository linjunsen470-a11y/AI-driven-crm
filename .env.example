# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Maoshan AI CRM
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Database
DATABASE_URL={{DATABASE_URL}}
# Optional: dedicated shadow database for migrations
SHADOW_DATABASE_URL={{SHADOW_DATABASE_URL_OPTIONAL}}

# Auth
AUTH_SECRET={{AUTH_SECRET}}

# Storage
# Local text-only and basic upload flows can keep using `local`.
# When you want local `n8n + MinIO` end-to-end processing, switch this to `minio`.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./.data/storage
# Suggested local MinIO bucket name:
STORAGE_BUCKET=maoshan-dev

# S3 / MinIO
# These S3_* variables are also used for MinIO.
# Suggested local MinIO dev values:
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY={{S3_ACCESS_KEY_OR_MINIO_ROOT_USER}}
S3_SECRET_KEY={{S3_SECRET_KEY_OR_MINIO_ROOT_PASSWORD}}
S3_FORCE_PATH_STYLE=true

# Upload Rules
MAX_UPLOAD_SIZE_MB=50
ALLOWED_AUDIO_MIME_TYPES=audio/wav,audio/mpeg,audio/mp4,audio/x-m4a,audio/webm

# Internal APIs / Callbacks
CRM_INTERNAL_API_BASE_URL=http://127.0.0.1:3000
CRM_INTERNAL_API_TOKEN={{CRM_INTERNAL_API_TOKEN}}
# n8n workers should call this route before provider work starts so CRM can mark jobs as running.
CRM_AI_JOB_START_PATH=/api/internal/ai-jobs/start
# Use the unified AI job callback until a dedicated transcription callback route is introduced.
CRM_TRANSCRIPTION_CALLBACK_PATH=/api/internal/ai-jobs/callback
CRM_AI_JOB_CALLBACK_PATH=/api/internal/ai-jobs/callback

# n8n
# Suggested local n8n dev values:
N8N_BASE_URL=http://127.0.0.1:5678
N8N_AI_JOB_WEBHOOK_PATH=/webhook/maoshan-ai-job
N8N_WEBHOOK_SECRET={{N8N_WEBHOOK_SECRET}}
N8N_REQUEST_TIMEOUT_MS=15000

# AI providers
OPENAI_API_KEY={{OPENAI_API_KEY}}
# Leave empty if using the provider default base URL
OPENAI_BASE_URL={{OPENAI_BASE_URL_OPTIONAL}}
OPENAI_MODEL=gpt-5.4

# Speech / OCR defaults
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OCR_MODEL=gpt-5.4-mini

# Knowledge / RAG
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

# Logging
LOG_LEVEL=info
