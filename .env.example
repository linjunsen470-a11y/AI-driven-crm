# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Maoshan AI CRM
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maoshan_ai_crm?schema=public"
# Optional: use a dedicated shadow database for migrations if needed
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maoshan_ai_crm_shadow?schema=public"

# Auth
AUTH_SECRET=replace-with-a-long-random-secret

# Storage
STORAGE_DRIVER=minio
STORAGE_LOCAL_ROOT=./.data/storage
STORAGE_BUCKET=crm-files

# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=replace-with-webhook-secret

# AI providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4

# Speech / OCR defaults
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OCR_MODEL=gpt-5.4-mini

# Knowledge / RAG
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

# Logging
LOG_LEVEL=info
